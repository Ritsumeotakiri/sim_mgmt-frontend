# Vite dev server
VITE_DEV_SERVER_PORT=5173
VITE_DEV_ALLOWED_HOSTS=

# Backend API proxy target for /api
VITE_API_PROXY_TARGET= your-backend-api-url-here

# Optional: comma-separated image URLs for the Login page left panel background
# Example: VITE_LOGIN_HERO_IMAGES=https://example.com/a.jpg,https://example.com/b.jpg
VITE_LOGIN_HERO_IMAGES=
